{
  "name": "markmind",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc && vite build",
    "build:web": "tsc && vite build",
    "preview": "vite preview",
    "pack:mcpb": "npx -y @anthropic-ai/mcpb pack mcpb markmind.mcpb",
    "tauri": "tauri",
    "setup:ffmpeg": "bash src-tauri/scripts/download-ffmpeg.sh",
    "tauri:build": "npm run setup:ffmpeg && npm run tauri build",
    "version:patch": "npm version patch --no-git-tag-version && node scripts/sync-version.mjs",
    "version:minor": "npm version minor --no-git-tag-version && node scripts/sync-version.mjs",
    "version:major": "npm version major --no-git-tag-version && node scripts/sync-version.mjs"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@fontsource/noto-serif-kr": "^5.2.9",
    "@google/genai": "^1.44.0",
    "@sereneinserenade/tiptap-search-and-replace": "^0.1.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-table": "^3.23.6",
    "@tiptap/extension-table-cell": "^3.23.6",
    "@tiptap/extension-table-header": "^3.23.6",
    "@tiptap/extension-table-row": "^3.23.6",
    "@tiptap/extension-task-item": "^3.23.6",
    "@tiptap/extension-task-list": "^3.23.6",
    "@tiptap/extension-typography": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@uiw/react-codemirror": "^4.25.7",
    "@xyflow/react": "^12.11.0",
    "d3-flextree": "^2.1.2",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "dagre": "^0.8.5",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.576.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/d3-force": "^3.0.10",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^2.1.9"
  }
}
